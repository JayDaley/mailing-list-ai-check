# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it. This template is the only credential
# file that belongs in the public repo.

# --- IMAP mail access ---
# IMAP_HOST is required for pulling mail. Point it at the IMAP server that
# hosts the mailing-list archive you want to check. If the server offers a
# documented anonymous/guest login, use that for IMAP_USERNAME/IMAP_PASSWORD;
# otherwise supply real credentials (kept only in this gitignored file).
IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=

# --- Pangram API (AI-text detection) ---
# Required only for scoring (mail-ai-score). Pulling, extraction, and the
# dashboard work without it. Get a key from https://www.pangram.com/
PANGRAM_API_KEY=

# --- Storage ---
# SQLite database path (default: ./data/mail.db; data/ is gitignored).
DATABASE_PATH=

# --- App settings ---
LOG_LEVEL=INFO

# --- Web dashboard (Flask API) ---
# Host/port for the `mail-ai-web` dev server (defaults: 127.0.0.1:8050).
FLASK_HOST=
FLASK_PORT=
